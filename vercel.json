{
  "buildCommand": "echo 'No build needed for static files'",
  "outputDirectory": ".",
  "installCommand": "echo 'No dependencies to install'",
  "env": {},
  "regions": ["iad1"],
  "public": true,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true
}
